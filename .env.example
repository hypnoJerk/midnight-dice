# ==============================================================================
# MIDNIGHT 1-4-24 ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' and adjust the variables to fit your environment.
# Do NOT commit your custom '.env' file containing actual secrets to source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Authoritative Backend Server Configurations
# ------------------------------------------------------------------------------

# The port the Express & Socket.io server listens on (inside the container)
PORT=3001

# Authoritative connection string to your PostgreSQL database instance.
# Local Docker Quickstart fallback: postgresql://postgres:postgres@db:5432/midnight_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/midnight_db

# Set to 'production' in live hosting environments, and 'development' for local tracing
NODE_ENV=development

# Database Maintenance & Reset Protocol Flags (Safety-guarded)
# Set to 'true' ONCE to drop all tables, purge data, and recreate pristine schemas.
# Leave blank or set to 'false' to maintain standard data persistence.
PURGE_DB=false
RESET_DB=false


# ------------------------------------------------------------------------------
# 2. Vite Client Frontend Configurations
# ------------------------------------------------------------------------------

# The public URL endpoint of the Express Server API. 
# Local development default: http://localhost:8080/api (proxied by Nginx)
# DigitalOcean subdomain example: https://midnight.yourdomain.com/api
VITE_API_URL=http://localhost:8080/api

# A comma-separated list of allowed host domains to authorize under Vite's security guard.
# Prevents "Blocked request: Host not allowed" DNS rebinding exceptions.
# Local development default: localhost,127.0.0.1
# DigitalOcean subdomain example: midnight.yourdomain.com,localhost
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
